# Claude AI - Ignore patterns
# Large files, sensitive data, and generated artifacts

# Virtual environments
.venv/
venv/
env/
__pycache__/
*.egg-info/

# Build & dist
build/
dist/
*.whl
*.egg

# Dependencies
node_modules/
.npm/

# Generated files
htmlcov/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyc
*.pyo
*.pyd
.DS_Store

# Database files
*.db
*.sqlite
*.sqlite3

# Large data files (>10MB)
data/
datasets/
*.tar.gz
*.zip

# Sensitive/config files
.env
.env.local
.env.*.local
secrets/
*.key
*.pem
*.p12
config.local.json
settings.local.json

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Logs
logs/
*.log
*.log.*

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store
.AppleDouble

# Cache files
*.cache
.cache/
cache/

# Lock files (already tracked via uv.lock)
package-lock.json
poetry.lock

# Test artifacts
test-results/
coverage-report/

*.log
