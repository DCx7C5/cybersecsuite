{
    "version": 1,
    "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python .github/scripts/load_hook_rules.py sessionStart",
        "powershell": "python .github/scripts/load_hook_rules.py sessionStart",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "printf 'sessionEnd\\n' >> \"${TMPDIR:-/tmp}/copilot-hooks.log\"",
        "powershell": "\"sessionEnd\" | Add-Content -Path (Join-Path $env:TEMP 'copilot-hooks.log')",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [],
    "preToolUse": [
      {
        "type": "command",
        "bash": "tee -a \"${TMPDIR:-/tmp}/copilot-hooks.log\" >/dev/null",
        "powershell": "($input | Out-String) | Add-Content -Path (Join-Path $env:TEMP 'copilot-hooks.log')",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "printf 'test hook: preToolUse\\n' >> \"${TMPDIR:-/tmp}/copilot-hooks.log\"",
        "powershell": "\"test hook: preToolUse\" | Add-Content -Path (Join-Path $env:TEMP 'copilot-hooks.log')",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "printf 'postToolUse\\n' >> \"${TMPDIR:-/tmp}/copilot-hooks.log\"",
        "powershell": "\"postToolUse\" | Add-Content -Path (Join-Path $env:TEMP 'copilot-hooks.log')",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "printf 'errorOccurred\\n' >> \"${TMPDIR:-/tmp}/copilot-hooks.log\"",
        "powershell": "\"errorOccurred\" | Add-Content -Path (Join-Path $env:TEMP 'copilot-hooks.log')",
        "timeoutSec": 5
      }
    ],
    "notification": [],
    "permissionRequest": [],
    "postToolUseFailure": [],
    "preCompact": [],
    "agentStop": [],
    "subagentStart": [
      {
        "type": "command",
        "bash": "python .github/scripts/load_hook_rules.py subagentStart",
        "powershell": "python .github/scripts/load_hook_rules.py subagentStart",
        "timeoutSec": 5
      }
    ],
    "subagentStop": []
  }
}
