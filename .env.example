# ─── Copy to .env and fill in secrets ────────────────────────────────────────
# cp .env.example .env && chmod 600 .env

SECRET_KEY="change_me_to_a_random_secret_key_for_session_signING_and_OTHER_THINGS"

## API Keys (fill in as needed for your investigations; optional) ───────────────────────────────

# NVIDIA_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
# TOGETHER_API_KEY=
# GEMINI_API_KEY=
# GITHUB_TOKEN=
# MISTRAL_API_KEY=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# FIREWORKS_API_KEY=
# OPENCODE_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
CYBERSEC_DB_HOST=
CYBERSEC_DB_PORT=
CYBERSEC_DB_USER=cybersec
CYBERSEC_DB_PASSWORD=change_me
CYBERSEC_DB_NAME=cybersec_forensics

# ── Startup behaviour ─────────────────────────────────────────────────────────
# Create DB + schema on first run (safe / idempotent)
CYBERSEC_AUTO_CREATE_DB=true
# Bootstrap MITRE/CVE/CWE intel on MCP start (slow, set false after first run)
CYBERSEC_BOOTSTRAP_INTEL_ON_START=false

# ── Data directories ─────────────────────────────────────────────────────────
CYBERSEC_BASE_DIR=./data
CYBERSEC_INTEL_DIR=./data/cybersec-shared/intelligence
CYBERSEC_PROJECT_DIR=.

# ── Scope defaults ────────────────────────────────────────────────────────────
CYBERSEC_WORKSPACE=default
CYBERSEC_PROJECT=default
# CYBERSEC_SESSION_ID=   # set per investigation session

# ── A2A server ────────────────────────────────────────────────────────────────
CYBERSEC_A2A_BASE_URL=http://127.0.0.1:8000
CYBERSEC_A2A_PORT=8000

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Python paths (set automatically by Makefile / start.sh) ──────────────────
# PYTHONPATH=src:/home/daen/Projects/AI


# ── OpenTelemetry / OpenObserve (LLM layer) ───────────────────────────────────
OPENOBSERVE_OTLP_ENDPOINT=http://127.0.0.1:5080/api/default
OPENOBSERVE_EMAIL=admin@cybersec.local
OPENOBSERVE_PASSWORD=cYb3rS3c!
OTEL_SERVICE_NAME=cybersecsuite-llm


# ── Telegram Chat ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Worktree session ──────────────────────────────────────────────────────────
# GWT_SID=<12-char hex>   # set automatically by gwt-create alias

# ── SecureMD / Prompt Injection Prevention ──────────────────────────────────────
# SECUREMD_ENABLED=true       # Master toggle; false = skip all signature verification
# SECUREMD_ENFORCE_HEADER=true # false = allow docs missing optional frontmatter fields

# ── QoL Output Controls ───────────────────────────────────────────────────────
# Comma-separated list of toggles active by default when no saved settings exist.
# Valid values: no_thinking, no_chat, minimal, file_only, no_markdown,
#               structured_only, redact_secrets, append_audit_trail
# QOL_DEFAULT_TOGGLES=no_thinking,no_chat

# Scope applied when no explicit scopes is provided (session | project | global).
# QOL_DEFAULT_SCOPE=session

# Maximum token budget for the injected directive block; emits a warning when exceeded.
# QOL_MAX_TOKENS=100
