{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_MAX_AGENTS": "5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_MAX_TASKS_PER_AGENT": "10",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_TASK_TIMEOUT_SECONDS": "3600",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_ENABLE_LOGGING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_LOG_LEVEL": "INFO"
  },
  "agent": "cybersec-agent",
  "version": "0.1.0",
  "asgi": {
    "host": "127.0.0.1",
    "port": 8000,
    "alt_port": 8080,
    "tls_port": 8433,
    "tls_cert": "~/.omniroute/certs/cert.pem",
    "tls_key": "~/.omniroute/certs/key.pem"
  },
  "mcp": {
    "servers": [
      "cybersec",
      "dystopian"
    ],
    "tool_prefix": "mcp__"
  },
  "proxy": {
    "enabled": true,
    "default_strategy": "cost-optimized",
    "prefer_free": false,
    "max_cost_per_1k_usd": null,
    "custom_providers_config": "~/.cybersecsuite/providers.yaml",
    "browser_providers": {
      "headless": true,
      "stealth": true,
      "profile_dir": null
    }
  },
  "crypto": {
    "algorithm": "Ed25519",
    "hash": "blake2b",
    "hash_digest_size": 32,
    "key_derivation": {
      "algorithm": "Argon2id",
      "memory_cost": 262144,
      "iterations": 4,
      "lanes": 4,
      "salt_length": 32
    },
    "encryption": {
      "algorithm": "AES-256-GCM",
      "nonce_length": 12,
      "tag_length": 16
    }
  },
  "signing": {
    "algorithm": "Ed25519",
    "token_format": "frontmatter.payload",
    "default_expiry_hours": 8760,
    "key_id": "default"
  },
  "artifacts": {
    "checksum_algorithm": "blake2b",
    "checksum_key": "artifact_integrity",
    "signature_log_enabled": true,
    "version_history_limit": 50
  },
  "keys": {
    "directory": "/etc/dystopian-crypto/keys",
    "metadata_subdir": ".metadata",
    "backup_subdir": ".backups",
    "permissions": {
      "private_key": "0600",
      "public_key": "0644",
      "metadata": "0600"
    }
  },
  "cache": {
    "integrity_key": "cache_integrity",
    "default_ttl_hours": 24
  },
  "security": {
    "min_password_length": 32,
    "require_password_file": true,
    "audit_logging": true
  },
  "hooks_dir": "hooks/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/hooks/pre_tool_call.py\""
          }
        ],
        "agents": [
          "cybersec-agent",
          "OrchestratorAgent",
          "PythonDeveloper",
          "CppDeveloper",
          "CybersecAgent"
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/hooks/post_tool_use.py\""
          }
        ],
        "agents": [
          "cybersec-agent",
          "OrchestratorAgent",
          "PythonDeveloper",
          "CppDeveloper",
          "CybersecAgent"
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/hooks/session_end.py\""
          }
        ],
        "agents": [
          "cybersec-agent",
          "OrchestratorAgent"
        ]
      }
    ],
    "FirstInit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/hooks/first_init.py\""
          }
        ],
        "agents": [
