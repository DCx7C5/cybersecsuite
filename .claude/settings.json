{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_MAX_AGENTS": "5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_MAX_TASKS_PER_AGENT": "10",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_TASK_TIMEOUT_SECONDS": "3600",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_ENABLE_LOGGING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS_LOG_LEVEL": "DEBUG"
  },
  "agent": "cybersec-agent",
  "version": "0.1.0",
  "asgi": {
    "host": "127.0.0.1",
    "port": 8000,
    "alt_port": 8080,
    "tls_port": 8433,
    "tls_cert": "~/.omniroute/certs/cert.pem",
    "tls_key": "~/.omniroute/certs/key.pem"
  },
  "mcp": {
    "servers": [
      "cybersec",
      "dystopian"
    ],
    "tool_prefix": "mcp__"
  },
  "proxy": {
    "enabled": true,
    "default_strategy": "cost-optimized",
    "prefer_free": false,
    "max_cost_per_1k_usd": null,
    "custom_providers_config": "~/.cybersecsuite/providers.yaml",
    "browser_providers": {
      "headless": true,
      "stealth": true,
      "profile_dir": null
    }
  },
  "crypto": {
    "algorithm": "Ed25519",
    "hash": "blake2b",
    "hash_digest_size": 32,
    "key_derivation": {
      "algorithm": "Argon2id",
      "memory_cost": 262144,
      "iterations": 4,
      "lanes": 4,
      "salt_length": 32
    },
    "encryption": {
      "algorithm": "AES-256-GCM",
      "nonce_length": 12,
      "tag_length": 16
    }
  },
  "signing": {
    "algorithm": "Ed25519",
    "token_format": "frontmatter.payload",
    "default_expiry_hours": 8760,
    "key_id": "default"
  },
  "artifacts": {
    "checksum_algorithm": "blake2b",
    "checksum_key": "artifact_integrity",
    "signature_log_enabled": true,
    "version_history_limit": 50
  },
  "keys": {
    "directory": "/etc/dystopian/crypto/cert/private",
    "metadata_subdir": ".metadata",
    "backup_subdir": ".backups",
    "permissions": {
      "private_key": "0600",
      "public_key": "0644",
      "metadata": "0600"
    }
  },
  "cache": {
    "integrity_key": "cache_integrity",
    "default_ttl_hours": 24
  },
  "security": {
    "min_password_length": 32,
    "require_password_file": true,
    "audit_logging": true
  },
  "qol": {
    "enabled": true,
    "default_scope": "session",
    "max_injection_tokens": 100,
    "cache_ttl_seconds": 300,
    "toggles": {
      "no_thinking": {
        "name": "no_thinking",
        "description": "Suppress reasoning/thinking blocks",
        "category": "output_suppression",
        "risky": false
      },
      "no_chat": {
        "name": "no_chat",
        "description": "Suppress conversational filler",
        "category": "output_suppression",
        "risky": false
      },
      "minimal": {
        "name": "minimal",
        "description": "Absolute minimum output — one-liners only",
        "category": "output_suppression",
        "risky": false
      },
      "file_only": {
        "name": "file_only",
        "description": "Only produce file/code output",
        "category": "output_suppression",
        "risky": true,
        "incompatible_with": ["append_audit_trail", "structured_only"]
      },
      "no_markdown": {
        "name": "no_markdown",
        "description": "Plain text output, no Markdown formatting",
        "category": "format_controls",
        "risky": false
      },
      "structured_only": {
        "name": "structured_only",
        "description": "Structured data output only (JSON/YAML/table)",
        "category": "format_controls",
        "risky": false,
        "incompatible_with": ["file_only"]
      },
      "redact_secrets": {
        "name": "redact_secrets",
        "description": "Auto-redact API keys, passwords, tokens",
        "category": "security_audit",
        "risky": false
      },
      "append_audit_trail": {
        "name": "append_audit_trail",
        "description": "Append audit trail (timestamp + model + hash) to output",
        "category": "security_audit",
        "risky": false,
        "incompatible_with": ["file_only", "minimal"]
      }
    },
    "presets": {
      "silent": {
        "name": "silent",
        "description": "Minimal output mode: suppress thinking, chat, and minimize response",
        "toggles": ["no_thinking", "no_chat", "minimal"],
        "source": "builtin"
      },
      "code-only": {
        "name": "code-only",
        "description": "File output only: code/files only, no chat or thinking",
        "toggles": ["file_only", "no_thinking", "no_chat"],
        "source": "builtin"
      },
      "structured": {
        "name": "structured",
        "description": "Structured data mode: JSON/YAML/table output with no reasoning",
        "toggles": ["structured_only", "no_thinking"],
        "source": "builtin"
      },
      "audit": {
        "name": "audit",
        "description": "Audit mode: redact secrets and append audit trail",
        "toggles": ["append_audit_trail", "redact_secrets"],
        "source": "builtin"
      },
      "plain-text": {
        "name": "plain-text",
        "description": "Plain text mode: no Markdown formatting or thinking",
        "toggles": ["no_markdown", "no_thinking"],
        "source": "builtin"
      }
    },
    "scope_cascade": true,
    "agent_preset_override": true
  },
  "hooks_dir": "src/hooks/",
  "hooks": {
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make ccs-first-setup"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/pre_tool_call.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/post_tool_use.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/session_end.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/first_init.py\" && python3 \"${workspaceFolder}/src/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/user_prompt_submit.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/agent_start.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/agent_end.py\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/termmate_idle.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/pre_compact.py\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${workspaceFolder}/src/hooks/post_compact.py\""
          }
        ]
      }
    ]
  }
}
