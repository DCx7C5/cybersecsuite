#!/usr/bin/env python3
"""
Network Hunter - Advanced network traffic analysis for APT detection
Part of MalwareHunter project for any Linux system

Usage: net-hunt [--capture] [--analyze] [--duration SECONDS]
"""
import argparse
import subprocess
import json
import os
import time
import re
import sys
from datetime import datetime
from pathlib import Path

# Add current directory to path for config import
sys.path.insert(0, str(Path(__file__).parent))
from config import get_config

class NetworkHunter:
    def __init__(self):
        self.config = get_config()
        self.session_dir = self.config.create_session_dir()
        self.network_dir = self.session_dir / "artifacts" / "network"
        self.network_dir.mkdir(parents=True, exist_ok=True)
        self.findings = []

    def log_finding(self, severity, title, description, evidence=None):
        finding = {
            "timestamp": datetime.now().isoformat(),
            "severity": severity,
            "title": title,
            "description": description,
            "evidence": evidence or [],
            "source": "net-hunt"
        }
        self.findings.append(finding)

        # Write to session findings
        findings_file = self.session_dir / "findings.md"
        with open(findings_file, "a") as f:
            f.write(f"## {finding['timestamp']} - {title}\n")
            f.write(f"**Severity:** {severity.upper()}\n")
            f.write(f"**Source:** net-hunt\n\n")
            f.write(f"{description}\n\n")
            if evidence:
                f.write("**Evidence:**\n")
                for item in evidence:
                    f.write(f"- {item}\n")
            f.write("\n---\n\n")

    def check_arp_table(self):
        """Check ARP table for spoofing indicators"""
        print("[*] Checking ARP table for anomalies...")

        try:
            # Get ARP table
            result = subprocess.run(['ip', 'neigh'], capture_output=True, text=True)
            if result.returncode != 0:
                print("[!] Failed to get ARP table")
                return

            arp_entries = []
            mac_to_ips = {}
            ip_to_macs = {}

            for line in result.stdout.split('\n'):
                if line.strip() and ('REACHABLE' in line or 'STALE' in line or 'PERMANENT' in line):
                    parts = line.split()
                    if len(parts) >= 5:
                        ip = parts[0]
                        mac = None
                        for part in parts:
                            if ':' in part and len(part) == 17:  # MAC address format
                                mac = part
                                break

                        if mac:
                            arp_entries.append((ip, mac, line))

                            # Track MAC to multiple IPs (potential spoofing)
                            if mac not in mac_to_ips:
                                mac_to_ips[mac] = []
                            mac_to_ips[mac].append(ip)

                            # Track IP to multiple MACs
                            if ip not in ip_to_macs:
                                ip_to_macs[ip] = []
                            ip_to_macs[ip].append(mac)

            # Check for ARP spoofing indicators
            for mac, ips in mac_to_ips.items():
                if len(ips) > 1:
                    self.log_finding("high", "Potential ARP Spoofing - Multiple IPs",
                                   f"MAC {mac} associated with multiple IPs: {ips}")

            for ip, macs in ip_to_macs.items():
                if len(macs) > 1:
                    self.log_finding("high", "Potential ARP Spoofing - Multiple MACs",
                                   f"IP {ip} associated with multiple MACs: {macs}")

            # Save ARP table snapshot
            arp_file = self.network_dir / "arp_table.txt"
            with open(arp_file, 'w') as f:
                f.write(result.stdout)

        except Exception as e:
            print(f"[!] Error checking ARP table: {e}")

    def check_active_connections(self):
        """Check active network connections for suspicious patterns"""
        print("[*] Checking active network connections...")

        try:
            # Get all network connections
            result = subprocess.run(['sudo', 'ss', '-tupln'], capture_output=True, text=True)
            if result.returncode != 0:
                print("[!] Failed to get network connections")
                return

            connections = result.stdout.split('\n')

            # Suspicious patterns
            suspicious_ports = [
                '1337', '31337', '4444', '5555', '6666', '7777',
                '8888', '9999', '12345', '54321', '6969'
            ]

            suspicious_ips = [
                '127.0.0.1:8080',  # Local proxy
                '0.0.0.0:',        # Listening on all interfaces
            ]

            for line in connections:
                if line.strip():
                    # Check for suspicious ports
                    for port in suspicious_ports:
                        if f':{port}' in line:
                            self.log_finding("medium", "Suspicious Port in Use",
                                           f"Potentially malicious port {port} in use: {line}")

                    # Check for processes listening on unusual ports
                    if 'LISTEN' in line:
                        # Extract process name
                        if 'users:((' in line:
                            process_match = re.search(r'users:\(\("([^"]+)"', line)
                            if process_match:
                                process_name = process_match.group(1)
                                # Flag unknown processes listening
                                known_processes = [
                                    'systemd', 'sshd', 'NetworkManager', 'dbus',
                                    'pulseaudio', 'brave', 'chrome', 'firefox'
                                ]
                                if not any(known in process_name for known in known_processes):
                                    self.log_finding("low", "Unknown Process Listening",
                                                   f"Unknown process listening on network: {line}")

            # Save connections snapshot
            connections_file = self.network_dir / "active_connections.txt"
            with open(connections_file, 'w') as f:
                f.write(result.stdout)

        except Exception as e:
            print(f"[!] Error checking connections: {e}")

    def check_routing_table(self):
        """Check routing table for anomalies"""
        print("[*] Checking routing table...")

        try:
            # Get routing table
            result = subprocess.run(['ip', 'route'], capture_output=True, text=True)
            if result.returncode != 0:
                print("[!] Failed to get routing table")
                return

            routes = result.stdout.split('\n')

            # Check for suspicious routes
            for line in routes:
                if line.strip():
                    # Look for routes to private networks that shouldn't be there
                    suspicious_patterns = [
                        r'10\.0\.0\.',      # Class A private
                        r'172\.1[6-9]\.',   # Class B private
                        r'172\.2[0-9]\.',   # Class B private
                        r'172\.3[0-1]\.',   # Class B private
                        r'192\.168\.',      # Class C private
                    ]

                    for pattern in suspicious_patterns:
                        if re.search(pattern, line) and 'default' not in line:
                            # Check if this is an unexpected private route
                            self.log_finding("low", "Unusual Private Network Route",
                                           f"Potentially suspicious private network route: {line}")

            # Save routing table
            routes_file = self.network_dir / "routing_table.txt"
            with open(routes_file, 'w') as f:
                f.write(result.stdout)

        except Exception as e:
            print(f"[!] Error checking routing table: {e}")

    def check_iptables_rules(self):
        """Check iptables/netfilter rules for malicious modifications"""
        print("[*] Checking iptables rules...")

        try:
            # Check various iptables tables
            tables = ['filter', 'nat', 'mangle', 'raw']

            for table in tables:
                result = subprocess.run(['sudo', 'iptables', '-t', table, '-L', '-n', '--line-numbers'],
                                      capture_output=True, text=True)
                if result.returncode == 0:
                    rules_content = result.stdout

                    # Save rules
                    rules_file = self.network_dir / f"iptables_{table}.txt"
                    with open(rules_file, 'w') as f:
                        f.write(rules_content)

                    # Check for suspicious patterns
                    suspicious_indicators = [
                        'REDIRECT',     # Traffic redirection
                        'DNAT',        # Destination NAT
                        'MASQUERADE',  # Source NAT masquerading
                        'DROP',        # Traffic dropping (if unexpected)
                        'REJECT',      # Traffic rejection
                    ]

                    for indicator in suspicious_indicators:
                        if indicator in rules_content:
                            # Count occurrences
                            count = rules_content.count(indicator)
                            if count > 5:  # Many rules might indicate malicious activity
                                self.log_finding("medium", f"Multiple {indicator} Rules",
                                               f"Found {count} {indicator} rules in {table} table")

                    # Check for rules targeting specific applications
                    if 'brave' in rules_content.lower() or 'browser' in rules_content.lower():
                        self.log_finding("high", "Browser-Targeted Firewall Rules",
                                       f"Firewall rules specifically targeting browser in {table} table")

        except Exception as e:
            print(f"[!] Error checking iptables: {e}")

    def capture_traffic(self, duration=60, interface=None):
        """Capture network traffic for analysis"""
        print(f"[*] Capturing network traffic for {duration} seconds...")

        try:
            # Determine interface if not specified
            if not interface:
                result = subprocess.run(['ip', 'route', 'get', '8.8.8.8'], capture_output=True, text=True)
                if result.returncode == 0:
                    # Extract interface from route output
                    match = re.search(r'dev (\w+)', result.stdout)
                    if match:
                        interface = match.group(1)
                    else:
                        interface = 'wlan0'  # Default fallback
                else:
                    interface = 'wlan0'

            print(f"[*] Using interface: {interface}")

            # Capture traffic with tcpdump
            capture_file = self.network_dir / f"traffic_capture_{int(time.time())}.pcap"

            # Start tcpdump
            tcpdump_cmd = [
                'sudo', 'tcpdump', '-i', interface, '-w', str(capture_file),
                '-s', '65535',  # Capture full packets
                '-n',  # Don't resolve hostnames
            ]

            print(f"[*] Starting packet capture...")
            process = subprocess.Popen(tcpdump_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

            # Wait for specified duration
            time.sleep(duration)

            # Stop tcpdump
            process.terminate()
            process.wait()

            if capture_file.exists():
                print(f"[+] Traffic capture saved to: {capture_file}")

                # Basic analysis of captured traffic
                self.analyze_pcap(capture_file)

                return capture_file
            else:
                print("[!] Failed to create capture file")
                return None

        except Exception as e:
            print(f"[!] Error capturing traffic: {e}")
            return None

    def analyze_pcap(self, pcap_file):
        """Analyze captured PCAP file"""
        print(f"[*] Analyzing captured traffic: {pcap_file}")

        try:
            # Use tshark for analysis
            if not subprocess.run(['which', 'tshark'], capture_output=True).returncode == 0:
                print("[!] tshark not available for analysis")
                return

            # Extract basic statistics
            result = subprocess.run(['tshark', '-r', str(pcap_file), '-q', '-z', 'conv,ip'],
                                  capture_output=True, text=True)

            if result.returncode == 0:
                stats_file = self.network_dir / f"traffic_stats_{int(time.time())}.txt"
                with open(stats_file, 'w') as f:
                    f.write(result.stdout)

                # Look for suspicious patterns in the statistics
                if 'Bytes' in result.stdout:
                    lines = result.stdout.split('\n')
                    for line in lines:
                        if '<->' in line and 'Bytes' in line:
                            # Parse connection info
                            parts = line.split()
                            if len(parts) >= 6:
                                bytes_total = parts[5]
                                if bytes_total.isdigit() and int(bytes_total) > 1000000:  # >1MB
                                    self.log_finding("low", "High Volume Connection",
                                                   f"Large data transfer detected: {line.strip()}")

            # Extract HTTP/HTTPS traffic
            result = subprocess.run(['tshark', '-r', str(pcap_file), '-Y', 'http || tls',
                                   '-T', 'fields', '-e', 'ip.src', '-e', 'ip.dst', '-e', 'http.host', '-e', 'tls.handshake.extensions_server_name'],
                                  capture_output=True, text=True)

            if result.returncode == 0 and result.stdout.strip():
                http_file = self.network_dir / f"http_traffic_{int(time.time())}.txt"
                with open(http_file, 'w') as f:
                    f.write(result.stdout)

                # Analyze domains/IPs
                domains = set()
                for line in result.stdout.split('\n'):
                    if line.strip():
                        parts = line.split('\t')
                        for part in parts:
                            if part and '.' in part and ' ' not in part:
                                domains.add(part)

                # Check for suspicious domains
                for domain in domains:
                    if domain and len(domain) > 3:
                        # Simple heuristics for suspicious domains
                        if (len(domain.split('.')) == 4 and all(part.isdigit() for part in domain.split('.'))):
                            # IP address instead of domain
                            self.log_finding("low", "Direct IP Connection",
                                           f"Connection to IP instead of domain: {domain}")
                        elif len(domain) > 50:  # Very long domain
                            self.log_finding("medium", "Suspicious Long Domain",
                                           f"Unusually long domain name: {domain}")

        except Exception as e:
            print(f"[!] Error analyzing PCAP: {e}")

    def run_hunt(self, capture_traffic=False, duration=60):
        """Run the network hunt"""
        print(f"[+] Starting network hunt")
        print(f"[+] Session directory: {self.session_dir}")

        # Static analysis
        self.check_arp_table()
        self.check_active_connections()
        self.check_routing_table()
        self.check_iptables_rules()

        # Dynamic analysis
        if capture_traffic:
            self.capture_traffic(duration)

        # Save findings
        findings_json = self.session_dir / "network_hunt_findings.json"
        with open(findings_json, 'w') as f:
            json.dump(self.findings, f, indent=2)

        print(f"\n[+] Network hunt complete. Found {len(self.findings)} indicators.")
        print(f"[+] Results saved to: {findings_json}")

        if self.findings:
            print("\n[!] FINDINGS SUMMARY:")
            for finding in self.findings:
                print(f"  {finding['severity'].upper()}: {finding['title']}")

def main():
    parser = argparse.ArgumentParser(description="Network Hunter - Advanced network traffic analysis")
    parser.add_argument("--capture", action="store_true", help="Capture network traffic")
    parser.add_argument("--analyze", action="store_true", help="Analyze existing captures")
    parser.add_argument("--duration", type=int, default=60, help="Capture duration in seconds")

    args = parser.parse_args()

    hunter = NetworkHunter()
    hunter.run_hunt(args.capture, args.duration)

if __name__ == "__main__":
    main()