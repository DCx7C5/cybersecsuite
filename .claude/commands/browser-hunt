#!/usr/bin/env python3
"""
Browser Forensics - Advanced browser compromise investigation
Part of MalwareHunter project for any Linux system

Usage: browser-hunt [--deep] [--browser brave|all] [--cookies] [--extensions]
"""
import argparse
import subprocess
import json
import os
import sqlite3
import shutil
import sys
from datetime import datetime
from pathlib import Path

# Add current directory to path for config import
sys.path.insert(0, str(Path(__file__).parent))
from config import get_config

class BrowserForensics:
    def __init__(self):
        self.config = get_config()
        self.session_dir = self.config.create_session_dir()
        self.browser_dir = self.session_dir / "artifacts" / "browser"
        self.browser_dir.mkdir(parents=True, exist_ok=True)
        self.findings = []

    def log_finding(self, severity, title, description, evidence=None):
        finding = {
            "timestamp": datetime.now().isoformat(),
            "severity": severity,
            "title": title,
            "description": description,
            "evidence": evidence or [],
            "source": "browser-hunt"
        }
        self.findings.append(finding)

        # Write to session findings
        findings_file = self.session_dir / "findings.md"
        with open(findings_file, "a") as f:
            f.write(f"## {finding['timestamp']} - {title}\n")
            f.write(f"**Severity:** {severity.upper()}\n")
            f.write(f"**Source:** browser-hunt\n\n")
            f.write(f"{description}\n\n")
            if evidence:
                f.write("**Evidence:**\n")
                for item in evidence:
                    f.write(f"- {item}\n")
            f.write("\n---\n\n")

    def get_browser_paths(self, browser="brave"):
        """Get browser configuration paths"""
        return self.config.get_browser_paths(browser)

    def analyze_browser_processes(self):
        """Analyze running browser processes"""
        print("[*] Analyzing browser processes...")

        try:
            # Find browser processes
            browsers = ["brave", "chrome", "chromium", "firefox"]
            browser_pids = {}

            for browser in browsers:
                result = subprocess.run(['pgrep', '-f', browser], capture_output=True, text=True)
                if result.returncode == 0:
                    pids = [pid.strip() for pid in result.stdout.split('\n') if pid.strip()]
                    if pids:
                        browser_pids[browser] = pids

            for browser, pids in browser_pids.items():
                for pid in pids:
                    # Check process memory maps
                    maps_file = f"/proc/{pid}/maps"
                    if os.path.exists(maps_file):
                        with open(maps_file, 'r') as f:
                            maps_content = f.read()

                        # Look for suspicious injected libraries
                        suspicious_patterns = [
                            '/tmp/',          # Temporary libraries
                            'deleted',        # Deleted files still in memory
                            '.so (deleted)',  # Deleted shared objects
                            'anonymous',      # Anonymous memory regions
                        ]

                        for pattern in suspicious_patterns:
                            if pattern in maps_content:
                                count = maps_content.count(pattern)
                                if count > 0:
                                    self.log_finding("medium", "Suspicious Browser Memory Mapping",
                                                   f"{browser} PID {pid}: {count} instances of {pattern}")

                    # Check process command line for suspicious flags
                    cmdline_file = f"/proc/{pid}/cmdline"
                    if os.path.exists(cmdline_file):
                        with open(cmdline_file, 'rb') as f:
                            cmdline = f.read().decode('utf-8', errors='ignore')

                        suspicious_flags = [
                            '--disable-web-security',
                            '--allow-running-insecure-content',
                            '--disable-features=VizDisplayCompositor',
                            '--remote-debugging-port',
                            '--disable-background-timer-throttling',
                            '--disable-renderer-backgrounding',
                        ]

                        for flag in suspicious_flags:
                            if flag in cmdline:
                                self.log_finding("high", "Suspicious Browser Command Line Flag",
                                               f"{browser} PID {pid}: {flag}")

                    # Check environment variables
                    environ_file = f"/proc/{pid}/environ"
                    if os.path.exists(environ_file):
                        with open(environ_file, 'rb') as f:
                            environ = f.read().decode('utf-8', errors='ignore')

                        if 'LD_PRELOAD' in environ:
                            preload_libs = [part.split('=')[1] for part in environ.split('\x00') if 'LD_PRELOAD=' in part]
                            self.log_finding("critical", "Browser Process LD_PRELOAD Injection",
                                           f"{browser} PID {pid}: LD_PRELOAD={preload_libs}")

        except Exception as e:
            print(f"[!] Error analyzing browser processes: {e}")

    def analyze_cookies(self, browser="brave"):
        """Analyze browser cookies for theft indicators"""
        print(f"[*] Analyzing {browser} cookies...")

        try:
            paths = self.get_browser_paths(browser)
            cookies_db = paths["cookies"]

            if not cookies_db or not cookies_db.exists():
                print(f"[!] {browser} cookies database not found")
                return

            # Check file timestamps
            stat_info = cookies_db.stat()
            import time
            current_time = time.time()

            # Check if cookies file was modified recently
            if current_time - stat_info.st_mtime < 3600:  # Modified in last hour
                self.log_finding("medium", "Recent Cookie Database Modification",
                               f"{browser} cookies database modified in last hour")

            # Copy cookies database for analysis
            cookies_copy = self.browser_dir / f"{browser}_cookies.db"
            try:
                shutil.copy2(cookies_db, cookies_copy)

                # Analyze cookies database
                conn = sqlite3.connect(cookies_copy)
                cursor = conn.cursor()

                # Get cookie statistics
                cursor.execute("SELECT name FROM sqlite_master WHERE type='table'")
                tables = cursor.fetchall()

                if ('cookies',) in tables:
                    # Count cookies by domain
                    cursor.execute("SELECT host_key, COUNT(*) as cookie_count FROM cookies GROUP BY host_key ORDER BY cookie_count DESC LIMIT 20")
                    top_domains = cursor.fetchall()

                    # Look for suspicious patterns
                    for domain, count in top_domains:
                        if count > 50:  # Many cookies for one domain
                            self.log_finding("low", "High Cookie Count for Domain",
                                           f"{browser}: {domain} has {count} cookies")

                        # Check for suspicious domain patterns
                        if any(pattern in domain for pattern in ['.onion', 'localhost', '127.0.0.1']):
                            self.log_finding("medium", "Suspicious Cookie Domain",
                                           f"{browser}: Cookies for suspicious domain {domain}")

                    # Check for authentication cookies
                    cursor.execute("SELECT host_key, name, value FROM cookies WHERE name LIKE '%auth%' OR name LIKE '%session%' OR name LIKE '%token%' LIMIT 10")
                    auth_cookies = cursor.fetchall()

                    if auth_cookies:
                        domains_with_auth = set([cookie[0] for cookie in auth_cookies])
                        self.log_finding("low", "Authentication Cookies Present",
                                       f"{browser}: Found auth cookies for domains: {list(domains_with_auth)}")

                conn.close()

            except sqlite3.Error as e:
                print(f"[!] Error analyzing cookies database: {e}")

        except Exception as e:
            print(f"[!] Error analyzing cookies: {e}")

    def analyze_browser_history(self, browser="brave"):
        """Analyze browser history for compromise indicators"""
        print(f"[*] Analyzing {browser} history...")

        try:
            paths = self.get_browser_paths(browser)
            history_db = paths["history"]

            if not history_db or not history_db.exists():
                print(f"[!] {browser} history database not found")
                return

            # Copy history database for analysis
            history_copy = self.browser_dir / f"{browser}_history.db"
            try:
                shutil.copy2(history_db, history_copy)

                conn = sqlite3.connect(history_copy)
                cursor = conn.cursor()

                # Get recent URLs
                cursor.execute("""
                    SELECT url, title, visit_count, last_visit_time
                    FROM urls
                    ORDER BY last_visit_time DESC
                    LIMIT 100
                """)
                recent_urls = cursor.fetchall()

                # Check for suspicious URL patterns
                suspicious_patterns = [
                    'localhost',
                    '127.0.0.1',
                    'file://',
                    '.onion',
                    'data:',
                    'javascript:',
                    'chrome-extension://',
                    'moz-extension://',
                ]

                for url, title, visit_count, last_visit in recent_urls:
                    for pattern in suspicious_patterns:
                        if pattern in url.lower():
                            self.log_finding("low", "Suspicious URL in History",
                                           f"{browser}: Suspicious URL visited: {url}")

                    # Check for very frequent visits to same URL
                    if visit_count > 100:
                        self.log_finding("low", "High Visit Count URL",
                                       f"{browser}: URL visited {visit_count} times: {url[:100]}")

                # Check for downloads
                cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='downloads'")
                if cursor.fetchone():
                    cursor.execute("""
                        SELECT target_path, url, start_time, total_bytes
                        FROM downloads
                        ORDER BY start_time DESC
                        LIMIT 20
                    """)
                    downloads = cursor.fetchall()

                    for target_path, url, start_time, total_bytes in downloads:
                        # Check for suspicious download locations
                        if '/tmp/' in target_path or '/dev/shm/' in target_path:
                            self.log_finding("medium", "Suspicious Download Location",
                                           f"{browser}: Download to suspicious location: {target_path}")

                        # Check for suspicious file extensions
                        if target_path.endswith(('.exe', '.scr', '.bat', '.cmd', '.pif', '.com')):
                            self.log_finding("high", "Suspicious File Downloaded",
                                           f"{browser}: Potentially malicious file downloaded: {target_path}")

                conn.close()

            except sqlite3.Error as e:
                print(f"[!] Error analyzing history database: {e}")

        except Exception as e:
            print(f"[!] Error analyzing history: {e}")

    def analyze_extensions(self, browser="brave"):
        """Analyze browser extensions for malicious activity"""
        print(f"[*] Analyzing {browser} extensions...")

        try:
            paths = self.get_browser_paths(browser)
            extensions_dir = paths["extensions"]

            if not extensions_dir or not extensions_dir.exists():
                print(f"[!] {browser} extensions directory not found")
                return

            # List all extensions
            for ext_dir in extensions_dir.iterdir():
                if ext_dir.is_dir():
                    extension_id = ext_dir.name

                    # Look for extension manifest
                    for version_dir in ext_dir.iterdir():
                        if version_dir.is_dir():
                            manifest_file = version_dir / "manifest.json"

                            if manifest_file.exists():
                                try:
                                    with open(manifest_file, 'r') as f:
                                        manifest = json.load(f)

                                    # Check permissions
                                    permissions = manifest.get("permissions", [])

                                    # Suspicious permissions
                                    suspicious_perms = [
                                        "tabs",
                                        "activeTab",
                                        "webRequest",
                                        "webRequestBlocking",
                                        "cookies",
                                        "storage",
                                        "management",
                                        "debugger",
                                        "desktopCapture",
                                        "nativeMessaging",
                                        "<all_urls>",
                                        "*://*/*",
                                    ]

                                    risky_perms = []
                                    for perm in permissions:
                                        if perm in suspicious_perms:
                                            risky_perms.append(perm)

                                    if risky_perms:
                                        ext_name = manifest.get("name", extension_id)
                                        self.log_finding("medium", "Extension with Risky Permissions",
                                                       f"{browser}: Extension '{ext_name}' ({extension_id}) has risky permissions: {risky_perms}")

                                    # Check for content scripts with broad access
                                    content_scripts = manifest.get("content_scripts", [])
                                    for script in content_scripts:
                                        matches = script.get("matches", [])
                                        for match in matches:
                                            if match in ["<all_urls>", "*://*/*", "http://*/*", "https://*/*"]:
                                                ext_name = manifest.get("name", extension_id)
                                                self.log_finding("high", "Extension with Broad Content Script Access",
                                                               f"{browser}: Extension '{ext_name}' can inject scripts into all websites")

                                except json.JSONDecodeError:
                                    pass

                    # Check extension files for suspicious content
                    js_files = list(version_dir.glob("**/*.js")) if version_dir.exists() else []
                    for js_file in js_files[:10]:  # Limit to first 10 files
                        try:
                            content = js_file.read_text(encoding='utf-8', errors='ignore')

                            # Look for suspicious patterns
                            suspicious_js_patterns = [
                                'eval(',
                                'Function(',
                                'document.write(',
                                'innerHTML =',
                                'btoa(',
                                'atob(',
                                'XMLHttpRequest',
                                'fetch(',
                                'chrome.cookies',
                                'chrome.storage',
                                'localStorage',
                                'sessionStorage',
                            ]

                            found_patterns = []
                            for pattern in suspicious_js_patterns:
                                if pattern in content:
                                    found_patterns.append(pattern)

                            if found_patterns:
                                ext_name = manifest.get("name", extension_id)
                                self.log_finding("low", "Extension with Suspicious JavaScript",
                                               f"{browser}: Extension '{ext_name}' contains suspicious JS patterns: {found_patterns}")

                        except Exception:
                            pass

        except Exception as e:
            print(f"[!] Error analyzing extensions: {e}")

    def check_browser_preferences(self, browser="brave"):
        """Check browser preferences for malicious modifications"""
        print(f"[*] Checking {browser} preferences...")

        try:
            paths = self.get_browser_paths(browser)
            prefs_file = paths["preferences"]

            if not prefs_file or not prefs_file.exists():
                print(f"[!] {browser} preferences file not found")
                return

            with open(prefs_file, 'r') as f:
                prefs = json.load(f)

            # Copy preferences for analysis
            prefs_copy = self.browser_dir / f"{browser}_preferences.json"
            shutil.copy2(prefs_file, prefs_copy)

            # Check for suspicious settings
            suspicious_settings = {
                "profile.default_content_setting_values.notifications": "Browser notifications enabled",
                "profile.default_content_settings.popups": "Popups allowed",
                "profile.managed_users": "Managed users configured",
                "browser.startup_urls": "Custom startup URLs",
                "extensions.settings": "Extension settings modifications",
            }

            for setting_path, description in suspicious_settings.items():
                current = prefs
                try:
                    for key in setting_path.split('.'):
                        current = current[key]

                    if current:
                        self.log_finding("low", "Suspicious Browser Setting",
                                       f"{browser}: {description} - {setting_path}: {current}")

                except KeyError:
                    pass

            # Check extensions settings for forced installations
            extensions = prefs.get("extensions", {}).get("settings", {})
            for ext_id, ext_info in extensions.items():
                if ext_info.get("was_installed_by_oem", False) or ext_info.get("was_installed_by_default", False):
                    self.log_finding("medium", "Pre-installed Extension",
                                   f"{browser}: Extension {ext_id} was pre-installed: {ext_info.get('manifest', {}).get('name', 'Unknown')}")

        except Exception as e:
            print(f"[!] Error checking preferences: {e}")

    def run_investigation(self, browser="all", deep=False, check_cookies=True, check_extensions=True):
        """Run browser forensics investigation"""
        print(f"[+] Starting browser forensics - Browser: {browser}, Deep: {deep}")
        print(f"[+] Session directory: {self.session_dir}")

        # Get available browsers from config
        available_browsers = {name: info for name, info in self.config.config['browsers'].items()
                            if info['installed']}

        if browser == "all":
            browsers_to_check = list(available_browsers.keys())
        elif browser in available_browsers:
            browsers_to_check = [browser]
        else:
            print(f"[!] Browser {browser} not found or not installed")
            return

        # Always check running processes
        self.analyze_browser_processes()

        for browser_name in browsers_to_check:
            print(f"\n[*] Investigating {browser_name}...")

            if check_cookies:
                self.analyze_cookies(browser_name)

            if deep:
                self.analyze_browser_history(browser_name)
                self.check_browser_preferences(browser_name)

            if check_extensions:
                self.analyze_extensions(browser_name)

        # Save findings
        findings_json = self.session_dir / "browser_forensics_findings.json"
        with open(findings_json, 'w') as f:
            json.dump(self.findings, f, indent=2)

        # Save system configuration
        self.config.save_config(self.session_dir)

        print(f"\n[+] Browser investigation complete. Found {len(self.findings)} indicators.")
        print(f"[+] Results saved to: {findings_json}")

        if self.findings:
            print("\n[!] FINDINGS SUMMARY:")
            for finding in self.findings:
                print(f"  {finding['severity'].upper()}: {finding['title']}")

def main():
    parser = argparse.ArgumentParser(description="Browser Forensics - Advanced browser compromise investigation")
    parser.add_argument("--deep", action="store_true", help="Perform deep analysis including history")
    parser.add_argument("--browser", choices=["brave", "chrome", "firefox", "all"], default="all",
                       help="Target browser (default: all)")
    parser.add_argument("--cookies", action="store_true", default=True, help="Analyze cookies")
    parser.add_argument("--extensions", action="store_true", default=True, help="Analyze extensions")

    args = parser.parse_args()

    forensics = BrowserForensics()
    forensics.run_investigation(args.browser, args.deep, args.cookies, args.extensions)

if __name__ == "__main__":
    main()