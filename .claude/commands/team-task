#!/usr/bin/env bash
# CyberSecSuite — /team-task slash command
# Usage: /team-task [blue|red|purple] <task description>
#
# Requires: CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 (set in settings.json)
#
# Examples:
#   /team-task blue "Hunt for lateral movement indicators in auth.log"
#   /team-task red "Enumerate attack surface of 192.168.1.0/24"
#   /team-task purple "Validate detection coverage for T1059.001 PowerShell"
#
# This command routes the task to the appropriate team agent defined in
# .claude/agents/teams/{team}-team.md and activates all relevant sub-agents.

TEAM="${1:-blue}"
shift
TASK="$*"

if [[ -z "$TASK" ]]; then
  echo "Usage: /team-task [blue|red|purple] <task description>"
  echo ""
  echo "Teams:"
  echo "  blue   — Defensive: threat hunting, IR, log analysis, hardening"
  echo "  red    — Offensive: recon, exploitation, persistence, C2"
  echo "  purple — Combined: validate detections, ATT&CK coverage mapping"
  exit 1
fi

TEAM_FILE=".claude/agents/teams/${TEAM}-team.md"
if [[ ! -f "$TEAM_FILE" ]]; then
  echo "✗ Unknown team: ${TEAM}. Valid teams: blue, red, purple"
  exit 1
fi

echo "🎯 Routing task to ${TEAM}-team..."
echo "   Task: ${TASK}"
echo ""
echo "Team configuration: ${TEAM_FILE}"
echo "Feature flag: CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1"
echo ""
echo "Activate with:"
echo "  claude --agent teams/${TEAM}-team --task \"${TASK}\""
