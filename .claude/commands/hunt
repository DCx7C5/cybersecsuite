#!/usr/bin/env python3
"""
APT Hunt - Advanced Persistent Threat Detection Command
Part of MalwareHunter project for any Linux system

Usage: apt-hunt [--quick|--deep] [--target process|network|browser|all]
"""
import argparse
import subprocess
import json
import os
import sys
from datetime import datetime
from pathlib import Path

# Add current directory to path for config import
sys.path.insert(0, str(Path(__file__).parent))
from config import get_config

class APTHunter:
    def __init__(self):
        self.config = get_config()
        self.session_dir = self.config.create_session_dir()
        self.findings = []

    def log_finding(self, severity, title, description, iocs=None):
        finding = {
            "timestamp": datetime.now().isoformat(),
            "severity": severity,
            "title": title,
            "description": description,
            "iocs": iocs or [],
            "source": "apt-hunt"
        }
        self.findings.append(finding)

        # Write to session findings
        findings_file = self.session_dir / "findings.md"
        with open(findings_file, "a") as f:
            f.write(f"## {finding['timestamp']} - {title}\n")
            f.write(f"**Severity:** {severity.upper()}\n")
            f.write(f"**Source:** apt-hunt\n\n")
            f.write(f"{description}\n\n")
            if iocs:
                f.write("**IOCs:**\n")
                for ioc in iocs:
                    f.write(f"- {ioc}\n")
            f.write("\n---\n\n")

    def check_suspicious_processes(self):
        """Check for suspicious processes and injections"""
        print("[*] Checking suspicious processes...")

        try:
            # Check for processes with unusual memory mappings
            if self.config.config['tools']['system_analysis']['lsof']:
                result = subprocess.run(['sudo', 'lsof', '-n', '-P'], capture_output=True, text=True)
                if result.returncode == 0:
                    suspicious_patterns = [
                        '/dev/nvidia',
                        '/dev/fb',
                        '/proc/*/mem',
                        'deleted',
                        'UNKNOWN'
                    ]

                    # Get legitimate services to filter out
                    legitimate_services = self.config.get_legitimate_services()

                    for line in result.stdout.split('\n'):
                        # Skip legitimate processes
                        if any(service.lower() in line.lower() for service in legitimate_services):
                            continue

                        for pattern in suspicious_patterns:
                            if pattern in line:
                                self.log_finding("medium", "Suspicious Process Memory Access",
                                               f"Process accessing {pattern}: {line}")

            # Check for unusual network connections
            if self.config.config['tools']['network_analysis']['ss']:
                result = subprocess.run(['sudo', 'ss', '-tulpn'], capture_output=True, text=True)
                if result.returncode == 0:
                    # Look for unusual network connections
                    lines = result.stdout.split('\n')
                    detected_browsers = [name for name, info in self.config.config['browsers'].items()
                                       if info['installed']]

                    for line in lines:
                        if ':443' in line:
                            # Check if it's from a known browser
                            is_browser = any(browser in line.lower() for browser in detected_browsers)
                            if not is_browser:
                                self.log_finding("low", "Unusual HTTPS Connection",
                                               f"Non-browser HTTPS connection: {line}")

        except Exception as e:
            print(f"[!] Error checking processes: {e}")

    def check_browser_compromise(self):
        """Check for browser compromise indicators"""
        print("[*] Checking browser compromise...")

        # Get available browsers from config
        available_browsers = {name: info for name, info in self.config.config['browsers'].items()
                            if info['installed']}

        if not available_browsers:
            print("[!] No browsers detected on system")
            return

        try:
            for browser_name, browser_info in available_browsers.items():
                # Find browser processes
                executable = browser_info.get('executable', browser_name)
                result = subprocess.run(['pgrep', '-f', executable], capture_output=True, text=True)
                if result.returncode == 0:
                    pids = result.stdout.strip().split('\n')
                    for pid in pids:
                        if pid:
                            # Check memory maps for suspicious libraries
                            maps_file = f"/proc/{pid}/maps"
                            if os.path.exists(maps_file):
                                with open(maps_file, 'r') as f:
                                    maps_content = f.read()
                                    if '/tmp/' in maps_content or 'deleted' in maps_content:
                                        self.log_finding("high", "Browser Process Memory Anomaly",
                                                       f"{browser_name} PID {pid} has suspicious memory mappings")

                # Check for cookie file modifications using dynamic paths
                browser_paths = self.config.get_browser_paths(browser_name)
                if 'cookies' in browser_paths:
                    cookie_path = browser_paths['cookies']
                    if cookie_path.exists():
                        stat_info = cookie_path.stat()
                        import time
                        if time.time() - stat_info.st_mtime < 3600:
                            self.log_finding("medium", "Recent Cookie File Modification",
                                           f"{browser_name} cookie file recently modified: {cookie_path}")

        except Exception as e:
            print(f"[!] Error checking browser: {e}")

    def check_network_anomalies(self):
        """Check for network-based APT indicators"""
        print("[*] Checking network anomalies...")

        try:
            # Check ARP table for spoofing
            result = subprocess.run(['ip', 'neigh'], capture_output=True, text=True)
            if result.returncode == 0:
                arp_entries = result.stdout.split('\n')
                seen_ips = set()
                for entry in arp_entries:
                    if 'REACHABLE' in entry or 'STALE' in entry:
                        parts = entry.split()
                        if len(parts) > 0:
                            ip = parts[0]
                            if ip in seen_ips:
                                self.log_finding("high", "Potential ARP Spoofing",
                                               f"Duplicate/suspicious ARP entry: {entry}")
                            seen_ips.add(ip)

            # Check for NAT rules that might hide C2 traffic
            result = subprocess.run(['sudo', 'iptables', '-t', 'nat', '-L', '-n'], capture_output=True, text=True)
            if result.returncode == 0:
                if 'MASQUERADE' in result.stdout or 'REDIRECT' in result.stdout:
                    self.log_finding("medium", "NAT Rules Present",
                                   f"NAT rules detected that could hide C2 traffic:\n{result.stdout}")

        except Exception as e:
            print(f"[!] Error checking network: {e}")

    def check_log_tampering(self):
        """Check for log tampering indicators"""
        print("[*] Checking for log tampering...")

        try:
            # Check journal integrity
            result = subprocess.run(['sudo', 'journalctl', '--verify'], capture_output=True, text=True)
            if result.returncode != 0:
                self.log_finding("critical", "Journal Integrity Failure",
                               f"Journal verification failed: {result.stderr}")

            # Check for missing log entries (time gaps)
            result = subprocess.run(['sudo', 'journalctl', '--since', '1 hour ago', '--until', 'now', '--no-pager'],
                                  capture_output=True, text=True)
            if result.returncode == 0:
                lines = result.stdout.split('\n')
                if len(lines) < 10:  # Very few log entries in last hour
                    self.log_finding("medium", "Suspicious Log Sparsity",
                                   "Very few journal entries in the last hour - possible log tampering")

            # Check for audit rule modifications
            if os.path.exists('/etc/audit/rules.d/'):
                result = subprocess.run(['sudo', 'auditctl', '-l'], capture_output=True, text=True)
                if result.returncode == 0:
                    if not result.stdout.strip():
                        self.log_finding("medium", "No Audit Rules",
                                       "No audit rules configured - monitoring may be disabled")

        except Exception as e:
            print(f"[!] Error checking logs: {e}")

    def check_gpu_framebuffer_access(self):
        """Check for GPU/framebuffer compromise (screenshot capability)"""
        print("[*] Checking GPU/framebuffer access...")

        try:
            gpu_config = self.config.config['gpu']

            # Check framebuffer devices from config
            for fb_dev in gpu_config['framebuffer_devices']:
                if os.path.exists(fb_dev):
                    stat_info = os.stat(fb_dev)
                    if stat_info.st_mode & 0o006:  # World readable/writable
                        self.log_finding("critical", "Framebuffer World Accessible",
                                       f"{fb_dev} is world accessible - screenshot capability possible")

            # Check NVIDIA device permissions from config
            for nvidia_dev in gpu_config['nvidia_devices']:
                if os.path.exists(nvidia_dev):
                    stat_info = os.stat(nvidia_dev)
                    if stat_info.st_mode & 0o006:
                        self.log_finding("high", "GPU Device World Accessible",
                                       f"{nvidia_dev} is world accessible")

            # Check for processes accessing GPU directly
            if gpu_config['nvidia_devices'] and self.config.config['tools']['system_analysis']['lsof']:
                result = subprocess.run(['sudo', 'lsof'] + gpu_config['nvidia_devices'],
                                      capture_output=True, text=True)
                if result.returncode == 0:
                    # Get legitimate display processes based on detected desktop
                    desktop_env = self.config.config['desktop']['environment']
                    legitimate_gpu_users = ['Xorg']

                    if desktop_env:
                        if 'gnome' in desktop_env.lower():
                            legitimate_gpu_users.extend(['gnome-shell', 'mutter'])
                        elif 'kde' in desktop_env.lower():
                            legitimate_gpu_users.extend(['kwin', 'plasmashell'])
                        elif 'cosmic' in desktop_env.lower():
                            legitimate_gpu_users.extend(['cosmic-comp'])

                    for line in result.stdout.split('\n'):
                        if line and not any(proc in line for proc in legitimate_gpu_users):
                            self.log_finding("medium", "Unusual GPU Access",
                                           f"Non-display process accessing GPU: {line}")

        except Exception as e:
            print(f"[!] Error checking GPU access: {e}")

    def run_hunt(self, mode="quick", target="all"):
        """Run the APT hunt"""
        print(f"[+] Starting APT hunt - Mode: {mode}, Target: {target}")
        print(f"[+] Session directory: {self.session_dir}")

        if target in ["all", "process"]:
            self.check_suspicious_processes()

        if target in ["all", "browser"]:
            self.check_browser_compromise()

        if target in ["all", "network"]:
            self.check_network_anomalies()

        if target in ["all", "logs"]:
            self.check_log_tampering()

        if target in ["all", "gpu"]:
            self.check_gpu_framebuffer_access()

        # Save findings
        findings_json = self.session_dir / "apt_hunt_findings.json"
        with open(findings_json, 'w') as f:
            json.dump(self.findings, f, indent=2)

        # Save system configuration
        self.config.save_config(self.session_dir)

        print(f"\n[+] Hunt complete. Found {len(self.findings)} indicators.")
        print(f"[+] Results saved to: {findings_json}")
        print(f"[+] System config saved to: {self.session_dir / 'system_config.json'}")

        if self.findings:
            print("\n[!] FINDINGS SUMMARY:")
            for finding in self.findings:
                print(f"  {finding['severity'].upper()}: {finding['title']}")

def main():
    parser = argparse.ArgumentParser(description="APT Hunt - Advanced Persistent Threat Detection")
    parser.add_argument("--mode", choices=["quick", "deep"], default="quick",
                       help="Hunt mode (default: quick)")
    parser.add_argument("--target", choices=["process", "browser", "network", "logs", "gpu", "all"],
                       default="all", help="Target area to hunt (default: all)")

    args = parser.parse_args()

    hunter = APTHunter()
    hunter.run_hunt(args.mode, args.target)

if __name__ == "__main__":
    main()