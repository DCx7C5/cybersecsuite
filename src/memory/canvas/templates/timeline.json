{
  "name": "Timeline",
  "description": "Horizontal event sequence with date markers. Good for project timelines and historical events.",
  "layout": "linear-horizontal",
  "defaults": {
    "event_count": 6,
    "gap": 100,
    "color_title": "6",
    "color_body": "5",
    "color_accent": "3"
  },
  "node_templates": [
    {
      "role": "event",
      "type": "text",
      "repeat": "$event_count",
      "repeat_default": 6,
      "text": "### Event {n}\n\n**Date**: Set date\n**What**: Describe the milestone.",
      "width": 280,
      "height": 160,
      "color": "$color_body"
    }
  ],
  "edge_templates": [
    {
      "from_role": "event",
      "to_role": "event",
      "pattern": "sequential"
    }
  ]
}
