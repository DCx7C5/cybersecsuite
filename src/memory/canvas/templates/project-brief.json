{
  "name": "Project Brief",
  "description": "Stacked zones for project kickoff: hero zone, objectives, and deliverables.",
  "layout": "linear-vertical",
  "defaults": {
    "objective_count": 3,
    "gap": 100,
    "color_title": "6",
    "color_body": "4",
    "color_accent": "5"
  },
  "node_templates": [
    {
      "role": "hero_zone",
      "type": "group",
      "repeat": 1,
      "label": "$title",
      "width": 1000,
      "height": 300,
      "color": "$color_title"
    },
    {
      "role": "hero_text",
      "type": "text",
      "repeat": 1,
      "group_role": "hero_zone",
      "text": "# $title\n\n**Client**: Set client name\n**Start**: Set start date\n**End**: Set end date\n**Status**: Planning",
      "width": 500,
      "height": 200,
      "color": "$color_title"
    },
    {
      "role": "objectives_zone",
      "type": "group",
      "repeat": 1,
      "label": "Objectives",
      "width": 1000,
      "height": 400,
      "color": "$color_body"
    },
    {
      "role": "objective",
      "type": "text",
      "repeat": "$objective_count",
      "repeat_default": 3,
      "group_role": "objectives_zone",
      "text": "### Objective {n}\n\n**Goal**: Describe the objective\n**KPI**: Measurable target\n**Owner**: Responsible person",
      "width": 300,
      "height": 160,
      "color": "$color_accent"
    },
    {
      "role": "deliverables_zone",
      "type": "group",
      "repeat": 1,
      "label": "Deliverables",
      "width": 1000,
      "height": 300,
      "color": "$color_accent"
    }
  ],
  "edge_templates": []
}
