{
  "manifest_version": 3,
  "name": "CyberSecSuite Agent",
  "version": "2.0.0",
  "description": "AI agent relay: intercepts API traffic, injects streaming prompts into forms, relays AJAX to CyberSecSuite SDK server.",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberSecSuite Agent"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
