# An .aiignore file follows the same syntax as a .gitignore file.
# .gitignore documentation: https://git-scm.com/docs/gitignore

# you can ignore files
.DS_Store
*.tmp


# JetBrains AI Assistant — excluded from AI context
# Syntax: same as .gitignore

# Compiled / cache
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments & dependencies
.venv/
node_modules/
*.egg-info/

# Fixtures & seed data (large JSON, not useful as AI context)
src/db/fixtures/
./data/

# Secrets & credentials
.env
.env.*
secrets/
*.key
*.pem
*.p12
uv.lock

# IDE state
.idea/
.vscode/

# Build / dist
dist/
build/
*.whl
*.tar.gz
*.zip

# Logs & temp
logs/
*.log
tmp/
temp/
# Test artefacts
htmlcov/
coverage.xml
.coverage


# AI Ignore Exclude

!.venv/bin/
!**data/
!/home/daen/Projects/ai-marketplace/index.json
!pyrightconfig.json
!pyproject.toml
!uv.lock
!docker-compose.yml
!Makefile
!manage.py




# Large / binary assets
*.js.map
dump.rdb
**/*.json
*.json
resume
legacy_docs/
src/legacy/
