# JetBrains AI Assistant — excluded from AI context
# Syntax: same as .gitignore

# Compiled / cache
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments & dependencies
.venv/
!.venv/bin/
node_modules/
*.egg-info/

# Fixtures & seed data (large JSON, not useful as AI context)
src/db/fixtures/
./data/

# Secrets & credentials
.env
.env.*
secrets/
*.key
*.pem
*.p12
uv.lock

# IDE state
.idea/
.vscode/

# Build / dist
dist/
build/
*.whl
*.tar.gz
*.zip

# Logs & temp
logs/
*.log
tmp/
temp/
!**data/
# Test artefacts
htmlcov/
coverage.xml
.coverage

# Large / binary assets
*.js.map
dump.rdb
