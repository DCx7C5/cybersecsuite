{
  "mcpServers": {
    "dystopian-crypto": {
      "name": "Dystopian Crypto",
      "description": "Ed25519 key management, artifact signing/verification (Argon2id + AES-256-GCM)",
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}",
        "run",
        "python",
        "-c",
        "import asyncio; from mcp.dystopian import dystopian_server; asyncio.run(dystopian_server.run_stdio())"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "DYSTOPIAN_KEYS_DIR": "/etc/dystopian-crypto/keys"
      },
      "cwd": "${workspaceFolder}"
    },
    "cybersec": {
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}",
        "run",
        "python",
        "mcp_server.py"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src:/home/daen/Projects/AI",
        "PLUGIN_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "CYBERSEC_BASE_DIR": "${workspaceFolder}/data",
        "CYBERSEC_DB_HOST": "localhost",
        "CYBERSEC_DB_PORT": "5432",
        "CYBERSEC_DB_USER": "cybersec",
        "CYBERSEC_DB_PASSWORD": "",
        "CYBERSEC_DB_NAME": "cybersec_forensics",
        "CYBERSEC_AUTO_CREATE_DB": "true",
        "CYBERSEC_BOOTSTRAP_INTEL_ON_START": "false",
        "CYBERSEC_INTEL_DIR": "${workspaceFolder}/data/cybersec-shared/intelligence"
      }
    },
    "kerneldev": {
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}",
        "run",
        "python",
        "-m",
        "kerneldev_mcp.server"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src:/home/daen/Projects/AI",
        "KERNEL_SRC": "/usr/src/linux-headers",
        "KERNELDEV_WORKSPACE": "${workspaceFolder}/.claude/skills/kerneldev-forensic/templates",
        "KERNELDEV_BUILD_OUTPUT": "${workspaceFolder}/kernel-modules-build",
        "KERNELDEV_SIGNING_KEY": "${workspaceFolder}/.claude/skills/kerneldev-forensic/templates/MOK.priv",
        "KERNELDEV_FORENSIC_MODE": "true"
      }
    },
    "token-optimization-mcp": {
      "name": "Token Optimization MCP",
      "description": "Token caching and optimization tools for LLM requests",
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}/mcps/token-optimization-mcp",
        "run",
        "python",
        "main.py"
      ],
      "env": {}
    },
    "playwright-stealth-mcp": {
      "name": "Playwright Stealth MCP",
      "description": "Playwright browser automation with stealth anti-detection",
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}/mcps/playwright-stealth-mcp",
        "run",
        "python",
        "main.py"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "${workspaceFolder}/.browsers"
      }
    }
  }
}